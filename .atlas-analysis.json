  "keyFeatures": [
    "Real-time inventory dashboard with KPI cards and monthly movement charts",
    "Control Perceptivo (warehouse receipts) with multi-line material entries",
    "Despachos (dispatches/exits) with PDF generation and validation workflow",
    "Stock management with configurable min/max thresholds and low-stock alerts",
    "Full CRUD for materials, categories, units of measure, suppliers, employees, and destinations",
    "JWT-based authentication stored in cookies with automatic token attachment on requests",
    "Clerk integration as an alternative authentication provider",
    "Audit log (Bitácora) for tracking all system actions per user",
    "User management with role-based access control",
    "RTL support, dark mode, configurable fonts, and responsive layout",
    "TanStack Router with file-based routing and automatic code-splitting",
    "TanStack Query for server state management"
  ],
  "publicApiSurface": [
    "POST /auth/login — authenticate with cédula and contraseña, returns JWT",
    "POST /auth/refresh-token — refresh access token",
    "GET /dashboard/stats — KPI stats, monthly movements, recent dispatches, stock by category",
    "GET /materiales — list all materials (with category and unit JOIN)",
    "GET /materiales/:id — get single material",
    "POST /materiales — create material",
    "PUT /materiales/:id — update material",
    "DELETE /materiales/:id — delete material",
    "GET /controles-perceptivos — list all warehouse receipts",
    "GET /controles-perceptivos/:id — get receipt with line details",
    "POST /controles-perceptivos — create warehouse receipt",
    "GET /salidas — list all dispatches",
    "GET /salidas/:id/pdf — download dispatch PDF",
    "POST /salidas — create dispatch",
    "GET /existencias — list stock levels",
    "PUT /existencias/:id — update min/max stock thresholds",
    "GET /categorias, POST, PUT, DELETE /categorias/:id",
    "GET /unidades-medida, POST, PUT, DELETE /unidades-medida/:id",
    "GET /destinos, POST, PUT, DELETE /destinos/:id",
    "GET /proveedores, POST, PUT, DELETE /proveedores/:id",
    "GET /empleados, POST, PUT, DELETE /empleados/:id",
    "GET /usuarios, POST, PUT, DELETE /usuarios/:id",
    "GET /bitacoras — audit log entries"
  ]
}
